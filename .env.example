# ── Required ──
NODE_ENV=development
PORT=5000
JWT_SECRET=change_me_to_a_random_64_hex_string
JWT_REFRESH_SECRET=change_me_to_a_different_random_hex_string
MONGODB_URI=mongodb://user:pass@localhost:27017/startup?authSource=admin

# ── Redis (optional — trending/engagement features need it) ──
REDIS_URL=redis://localhost:6379

# ── Logging ──
LOG_LEVEL=info

# ── Optional — Cloudinary (image uploads) ──
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Firebase Frontend Config (required for social login) ──
VITE_API_BASE_URL=http://localhost:5000/api
VITE_SOCKET_URL=ws://localhost:5000
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ── Firebase Admin Service Account (JSON string, required backend token verify) ──
FIREBASE_SERVICE_ACCOUNT=

# ── Hugging Face (free tier AI hairstyle generation — leave blank to use template overlay) ──
HF_TOKEN=
HF_MODEL=black-forest-labs/FLUX.1-schnell

# ── SMTP (transactional emails — leave blank to log to console in dev) ──
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@glowup.app

# ── Paystack (payments) ──
PAYSTACK_SECRET_KEY=
VITE_PAYSTACK_PUBLIC_KEY=

# ── LiveKit (live streaming — free tier at cloud.livekit.io, no credit card) ──
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_WS_URL=

# ── Upload limit (MB, default 100 — also used by Nginx client_max_body_size) ──
MAX_UPLOAD_SIZE_MB=100

# ── Client URL (CORS origin) ──
CLIENT_URL=http://localhost:5173

# ── Sentry (error tracking — leave blank to disable) ──
SENTRY_DSN=
VITE_SENTRY_DSN=

# ── Microsoft Clarity (analytics — leave blank to disable) ──
VITE_CLARITY_PROJECT_ID=
